// A partial meant to be @import-ed. Leading-underscore naming is a convention;
// go-styl does not require it. Variables and mixins defined here are shared with
// the importing file.

primary = #2d8cf0
danger = #ed4014
radius = 4px

button(bg)
  display inline-block
  padding 6px 12px
  border-radius radius
  background bg
  color white
